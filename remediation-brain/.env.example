# =============================================================================
# remediation-brain — Environment Variables Reference
# =============================================================================
# These variables are injected via docker-compose.yml using variable
# substitution from the ROOT .env file (not this file directly).
#
# To override locally:
#   1. Copy root .env.example to .env  (make setup)
#   2. Fill in your real values
#   3. Run: make up
# =============================================================================

# --- Groq (LangGraph LLM backend) ---
# Free API key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Infrastructure (set automatically by docker-compose) ---
DATABASE_URL=postgresql+asyncpg://auralis:auralis@postgres:5432/auralis
LANGGRAPH_DB_URL=postgresql://auralis:auralis@postgres:5432/auralis
REDIS_URL=redis://redis:6379
REDIS_STREAM=auralis:events

# --- GitHub (GitOps PR generation — used by enforce_node) ---
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=your-org/auralisapi
GITHUB_BRANCH=main

# --- App settings ---
LOG_LEVEL=info
ENVIRONMENT=development
SECRET_KEY=changeme-use-a-long-random-string-in-production
