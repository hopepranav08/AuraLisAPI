# AuralisAPI — root .gitignore

# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env
.env.local
**/.env

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/
*.tar

# ── Go build artifacts ────────────────────────────────────────────────────────
ebpf-sensor/ebpf-sensor
ebpf-sensor/*_bpfeb.go
ebpf-sensor/*_bpfel.go
ebpf-sensor/*.o

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
dist/

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
build.log
**/*.log

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
