# =============================================================================
# AuralisAPI — Root Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env     (Linux/macOS/Git Bash/WSL)
#   copy .env.example .env   (Windows cmd)
#
# .env is gitignored — never commit real secrets.
# docker-compose automatically loads .env from the project root.
# =============================================================================

# --- Groq (LangGraph LLM backend) ---
# Free API key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- GitHub (GitOps PR generation — used by enforce_node) ---
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=your-org/auralisapi
GITHUB_BRANCH=main

# --- App settings ---
SECRET_KEY=changeme-use-a-long-random-string-in-production
ENVIRONMENT=development
LOG_LEVEL=info

# --- Sensor mode ---
# mock  = replay fixtures (default, works on Windows)
# live  = real eBPF kernel injection (Linux host only)
SENSOR_MODE=mock
