{
    "$schema": "https://www.krakend.io/schema/v3.json",
    "version": 3,
    "name": "AuralisAPI Gateway",
    "port": 8080,
    "timeout": "10s",
    "cache_ttl": "300s",
    "output_encoding": "json",
    "extra_config": {
        "telemetry/logging": {
            "level": "INFO",
            "prefix": "[KRAKEND]",
            "syslog": false,
            "stdout": true
        },
        "security/cors": {
            "allow_origins": ["*"],
            "allow_methods": ["GET", "POST", "PUT", "DELETE", "PATCH"],
            "allow_headers": ["Authorization", "Content-Type"],
            "expose_headers": ["Content-Length"],
            "max_age": "12h"
        }
    },
    "endpoints": [
        {
            "endpoint": "/api/brain/health",
            "method": "GET",
            "output_encoding": "json",
            "backend": [
                {
                    "url_pattern": "/health",
                    "host": ["http://remediation-brain:8000"],
                    "encoding": "json"
                }
            ]
        },
        {
            "endpoint": "/api/inventory",
            "method": "GET",
            "output_encoding": "json",
            "backend": [
                {
                    "url_pattern": "/inventory",
                    "host": ["http://remediation-brain:8000"],
                    "encoding": "json"
                }
            ]
        },
        {
            "endpoint": "/api/incidents",
            "method": "GET",
            "output_encoding": "json",
            "backend": [
                {
                    "url_pattern": "/incidents",
                    "host": ["http://remediation-brain:8000"],
                    "encoding": "json"
                }
            ]
        },
        {
            "endpoint": "/api/remediate",
            "method": "POST",
            "output_encoding": "json",
            "backend": [
                {
                    "url_pattern": "/remediate",
                    "host": ["http://remediation-brain:8000"],
                    "encoding": "json"
                }
            ]
        },
        {
            "endpoint": "/api/v1/{endpoint}",
            "method": "GET",
            "output_encoding": "json",
            "backend": [
                {
                    "url_pattern": "/gone",
                    "host": ["http://remediation-brain:8000"],
                    "encoding": "json"
                }
            ],
            "extra_config": {
                "proxy/static": {
                    "data": {
                        "error": "Gone",
                        "code": 410,
                        "message": "This API version has been decommissioned per OWASP API9:2023. Migrate to /api/v3/.",
                        "sunset": "2025-01-01T00:00:00Z",
                        "docs": "https://github.com/your-org/auralisapi/blob/main/MIGRATION.md"
                    },
                    "strategy": "always"
                }
            }
        },
        {
            "endpoint": "/api/v1/{endpoint}/{sub}",
            "method": "GET",
            "output_encoding": "json",
            "backend": [
                {
                    "url_pattern": "/gone",
                    "host": ["http://remediation-brain:8000"],
                    "encoding": "json"
                }
            ],
            "extra_config": {
                "proxy/static": {
                    "data": {
                        "error": "Gone",
                        "code": 410,
                        "message": "This API version has been decommissioned per OWASP API9:2023. Migrate to /api/v3/.",
                        "sunset": "2025-01-01T00:00:00Z"
                    },
                    "strategy": "always"
                }
            }
        },
        {
            "endpoint": "/api/v1/{endpoint}",
            "method": "POST",
            "output_encoding": "json",
            "backend": [
                {
                    "url_pattern": "/gone",
                    "host": ["http://remediation-brain:8000"],
                    "encoding": "json"
                }
            ],
            "extra_config": {
                "proxy/static": {
                    "data": {
                        "error": "Gone",
                        "code": 410,
                        "message": "This API version has been decommissioned per OWASP API9:2023. Migrate to /api/v3/.",
                        "sunset": "2025-01-01T00:00:00Z"
                    },
                    "strategy": "always"
                }
            }
        },
        {
            "endpoint": "/api/v1/{endpoint}/{sub}",
            "method": "POST",
            "output_encoding": "json",
            "backend": [
                {
                    "url_pattern": "/gone",
                    "host": ["http://remediation-brain:8000"],
                    "encoding": "json"
                }
            ],
            "extra_config": {
                "proxy/static": {
                    "data": {
                        "error": "Gone",
                        "code": 410,
                        "message": "This API version has been decommissioned per OWASP API9:2023. Migrate to /api/v3/.",
                        "sunset": "2025-01-01T00:00:00Z"
                    },
                    "strategy": "always"
                }
            }
        }
    ]
}
